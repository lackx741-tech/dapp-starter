# WalletConnect Project ID — get one free at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Alchemy API Key — get one free at https://www.alchemy.com
NEXT_PUBLIC_ALCHEMY_API_KEY=your_alchemy_key_here

# Bundler URL for ERC-4337 UserOperations (e.g. Pimlico, Alchemy, Biconomy)
NEXT_PUBLIC_BUNDLER_URL=https://api.pimlico.io/v2/base/rpc?apikey=your_key

# Your app's public URL (used for WalletConnect metadata in SSR)
NEXT_PUBLIC_APP_URL=https://your-app.com
